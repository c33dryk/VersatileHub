## Patrones de Código

### Docker Compose (Template)
```yaml
services:
  [nombre]:
    container_name: ${PROJECT_NAME:-versatilehub}-[nombre]
    image: [imagen]:[tag]
    restart: unless-stopped
    networks:
      - versatilehub-network
    volumes:
      - ./data:/app/data
    environment:
      - VAR=${VAR}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:PORT/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.[nombre].rule=Host(`[nombre].${DOMAIN}`)"
      - "traefik.http.routers.[nombre].entrypoints=websecure"
      - "traefik.http.routers.[nombre].tls.certresolver=letsencrypt"

networks:
  versatilehub-network:
    external: true
```

